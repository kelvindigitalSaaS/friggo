import { useState, useEffect } from "react";
import { useNavigate } from "react-router-dom";
import { supabase } from "@/integrations/supabase/client";
import { useAuth } from "@/hooks/useAuth";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogHeader,
  DialogTitle
} from "@/components/ui/dialog";
import {
  Sparkles,
  Mail,
  Lock,
  Eye,
  EyeOff,
  ArrowRight,
  User,
  Refrigerator,
  ShoppingCart,
  Clock,
  Leaf,
  ChefHat,
  Bell,
  Loader2,
  KeyRound,
  CheckCircle2,
  ArrowLeft,
  UserPlus,
  LogIn,
  Play,
  Star
} from "lucide-react";
import { toast } from "sonner";
import fridgeVideo from "@/assets/fridge-video.mp4";
import { cn } from "@/lib/utils";
import { isNative, isIOS } from "@/lib/capacitor";
import { openExternalUrl } from "@/lib/nativeBrowser";

type AuthView = "landing" | "login" | "register";

export default function Auth() {
  const navigate = useNavigate();
  const { user, loading: authLoading } = useAuth();
  const [view, setView] = useState<AuthView>("landing");
  const [showPassword, setShowPassword] = useState(false);
  const [loading, setLoading] = useState(false);
  const [mounted, setMounted] = useState(false);
  const [videoError, setVideoError] = useState(false);

  // Form state
  const [formData, setFormData] = useState({
    email: "",
    password: "",
    name: "",
    confirmPassword: ""
  });

  // Password reset state
  const [resetEmail, setResetEmail] = useState("");
  const [resetLoading, setResetLoading] = useState(false);
  const [resetSent, setResetSent] = useState(false);
  const [resetDialogOpen, setResetDialogOpen] = useState(false);

  useEffect(() => {
    setMounted(true);
  }, []);

  // Redirect if already logged in
  useEffect(() => {
    if (user && !authLoading) {
      navigate("/");
    }
  }, [user, authLoading, navigate]);

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();

    if (!formData.email || !formData.password) {
      toast.error("Preencha todos os campos");
      return;
    }

    if (view === "register") {
      if (formData.password !== formData.confirmPassword) {
        toast.error("As senhas não coincidem");
        return;
      }
      if (formData.password.length < 6) {
        toast.error("A senha deve ter pelo menos 6 caracteres");
        return;
      }
    }

    setLoading(true);

    try {
      if (view === "login") {
        const { error } = await supabase.auth.signInWithPassword({
          email: formData.email,
          password: formData.password
        });
        if (error) throw error;
        toast.success("Login realizado com sucesso!");
        navigate("/");
      } else {
        const redirectUrl = isNative
          ? "friggo://auth/callback"
          : window.location.origin;
        const { data, error } = await supabase.auth.signUp({
          email: formData.email,
          password: formData.password,
          options: {
            data: { name: formData.name },
            emailRedirectTo: redirectUrl
          }
        });
        if (error) throw error;

        // Create profile using upsert to avoid duplicate key error
        if (data.user) {
          await supabase.from("profiles").upsert(
            {
              user_id: data.user.id,
              name: formData.name,
              onboarding_completed: false
            },
            { onConflict: "user_id" }
          );
        }

        // Check if email confirmation is required
        if (data.user && !data.session) {
          toast.success("Verifique seu email para confirmar a conta!", {
            duration: 6000,
            description:
              "Enviamos um link de confirmação para " + formData.email
          });
          setView("login");
          return;
        }

        toast.success("Conta criada! Bem-vindo ao FRIGGO!");
        navigate("/");
      }
    } catch (error: any) {
      let message = "Erro ao processar. Tente novamente.";
      if (!navigator.onLine) {
        message = "Sem conexão com a internet. Verifique sua rede.";
      } else if (
        error.message === "Invalid login credentials" ||
        error.message?.includes("invalid_credentials")
      ) {
        message = "Email ou senha incorretos. Verifique e tente novamente.";
      } else if (error.message?.includes("Email not confirmed")) {
        message =
          "Confirme seu email antes de entrar. Verifique sua caixa de entrada.";
      } else if (
        error.message?.includes("already registered") ||
        error.message?.includes("User already registered")
      ) {
        message = "Este email já está cadastrado. Faça login.";
      } else if (error.message?.includes("Password should be at least")) {
        message = "A senha deve ter pelo menos 6 caracteres.";
      } else if (
        error.message?.includes("Too many requests") ||
        error.status === 429
      ) {
        message =
          "Muitas tentativas. Aguarde alguns minutos e tente novamente.";
      } else if (error.message?.includes("weak_password")) {
        message = "Senha fraca. Use letras, números e símbolos.";
      } else if (error.message) {
        message = error.message;
      }
      toast.error(message, { duration: 5000 });
    } finally {
      setLoading(false);
    }
  };

  const handleGoogleSignIn = async () => {
    setLoading(true);
    try {
      if (isNative) {
        const { data, error } = await supabase.auth.signInWithOAuth({
          provider: "google",
          options: {
            redirectTo: "friggo://auth/callback",
            skipBrowserRedirect: true
          }
        });
        if (error) throw error;
        if (data.url) {
          await openExternalUrl(data.url);
        }
      } else {
        const { error } = await supabase.auth.signInWithOAuth({
          provider: "google",
          options: {
            redirectTo: window.location.origin
          }
        });
        if (error) throw error;
      }
    } catch (error: any) {
      toast.error(error.message || "Erro ao entrar com Google");
      setLoading(false);
    }
  };

  const handleAppleSignIn = async () => {
    setLoading(true);
    try {
      if (isNative) {
        const { data, error } = await supabase.auth.signInWithOAuth({
          provider: "apple",
          options: {
            redirectTo: "friggo://auth/callback",
            skipBrowserRedirect: true
          }
        });
        if (error) throw error;
        if (data.url) {
          await openExternalUrl(data.url);
        }
      } else {
        const { error } = await supabase.auth.signInWithOAuth({
          provider: "apple",
          options: {
            redirectTo: window.location.origin
          }
        });
        if (error) throw error;
      }
    } catch (error: any) {
      toast.error(error.message || "Erro ao entrar com a Apple");
      setLoading(false);
    }
  };

  const handlePasswordReset = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!resetEmail) {
      toast.error("Digite seu email");
      return;
    }

    setResetLoading(true);
    try {
      const { error } = await supabase.auth.resetPasswordForEmail(resetEmail, {
        redirectTo: `${window.location.origin}/auth`
      });
      if (error) throw error;
      setResetSent(true);
      toast.success("Email enviado! Verifique sua caixa de entrada.");
    } catch (error: any) {
      toast.error(error.message || "Erro ao enviar email");
    } finally {
      setResetLoading(false);
    }
  };

  const closeResetDialog = () => {
    setResetDialogOpen(false);
    setResetSent(false);
    setResetEmail("");
  };

  const goToLanding = () => {
    setView("landing");
    setFormData({ email: "", password: "", name: "", confirmPassword: "" });
  };

  const features = [
    { icon: Refrigerator, label: "Controle total" },
    { icon: Clock, label: "Alertas smart" },
    { icon: ShoppingCart, label: "Lista inteligente" },
    { icon: ChefHat, label: "Receitas IA" }
  ];

  const benefits = [
    "Reduza o desperdício em até 40%",
    "Receitas com o que você tem",
    "Alertas antes de vencer"
  ];

  if (authLoading) {
    return (
      <div className="min-h-screen flex items-center justify-center">
        <Loader2 className="h-8 w-8 animate-spin text-primary" />
      </div>
    );
  }

  return (
    <div className="min-h-screen relative overflow-hidden bg-white dark:bg-gray-950">
      {/* Video Background - hidden on error (Safari fallback to gradient) */}
      <div className="absolute inset-0">
        {!videoError && (
          <video
            autoPlay
            loop
            muted
            playsInline
            data-webkit-playsinline="true"
            preload="metadata"
            onError={() => setVideoError(true)}
            className="absolute inset-0 w-full h-full object-cover scale-105"
          >
            <source src={fridgeVideo} type="video/mp4" />
          </video>
        )}
      </div>

      {/* Overlay Gradient */}
      <div
        className={cn(
          "absolute inset-0 transition-all duration-700",
          view === "landing"
            ? "bg-gradient-to-b from-white/40 via-white/80 to-white dark:from-gray-950/40 dark:via-gray-950/80 dark:to-gray-950"
            : "bg-white/90 backdrop-blur-md dark:bg-gray-950/90"
        )}
      />

      {/* Content */}
      <div className="relative z-10 min-h-screen flex flex-col safe-area-inset">
        {/* LANDING VIEW */}
        {view === "landing" && (
          <div className="flex-1 flex flex-col">
            {/* Top Section */}
            <div className="flex-1 flex flex-col justify-end pb-6">
              {/* Logo and Branding */}
              <div
                className={cn(
                  "flex flex-col items-center px-6 transition-all duration-700",
                  mounted
                    ? "opacity-100 translate-y-0"
                    : "opacity-0 translate-y-8"
                )}
              >
                <div className="relative mb-5">
                  <div className="flex h-28 w-28 items-center justify-center rounded-[2rem] shadow-sm transition-transform duration-300">
                    <Sparkles className="h-14 w-14 text-primary-foreground" />
                  </div>
                  <div className="absolute -right-1 -top-1 h-6 w-6 rounded-full bg-fresh animate-pulse shadow-sm " />
                  <div className="absolute -left-2 -bottom-1 h-4 w-4 rounded-full bg-warning/80 animate-pulse shadow-sm" />
                </div>
                <h1 className="text-5xl font-bold tracking-tight text-foreground mb-1">
                  FRIGGO
                </h1>
                <p className="text-gray-500 text-center text-lg max-w-[280px] leading-relaxed font-medium">
                  Trazendo{" "}
                  <span className="text-primary font-bold">tecnologia</span> pra
                  sua casa
                </p>
              </div>
            </div>

            {/* Features Pills */}
            <div
              className={cn(
                "px-4 mb-6 transition-all duration-700 delay-100",
                mounted
                  ? "opacity-100 translate-y-0"
                  : "opacity-0 translate-y-8"
              )}
            >
              <div className="flex justify-center gap-2 flex-wrap max-w-sm mx-auto">
                {features.map((feature, i) => (
                  <div
                    key={i}
                    className="flex items-center gap-2 px-4 py-2.5 rounded-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 backdrop-blur-xl shadow-sm"
                  >
                    <feature.icon className="h-4 w-4 text-primary" />
                    <span className="text-sm font-medium text-foreground">
                      {feature.label}
                    </span>
                  </div>
                ))}
              </div>
            </div>

            {/* Benefits List */}
            <div
              className={cn(
                "px-6 mb-6 transition-all duration-700 delay-150",
                mounted
                  ? "opacity-100 translate-y-0"
                  : "opacity-0 translate-y-8"
              )}
            >
              <div className="max-w-sm mx-auto space-y-2">
                {benefits.map((benefit, i) => (
                  <div
                    key={i}
                    className="flex items-center gap-3 text-gray-500"
                  >
                    <div className="h-5 w-5 rounded-full bg-primary/20 flex items-center justify-center flex-shrink-0">
                      <CheckCircle2 className="h-3.5 w-3.5 text-primary" />
                    </div>
                    <span className="text-sm">{benefit}</span>
                  </div>
                ))}
              </div>
            </div>

            {/* Action Buttons */}
            <div
              className={cn(
                "px-6 pb-8 transition-all duration-700 delay-200",
                mounted
                  ? "opacity-100 translate-y-0"
                  : "opacity-0 translate-y-8"
              )}
            >
              <div className="max-w-sm mx-auto space-y-3">
                {/* Google Sign In - Primary CTA */}
                <Button
                  onClick={handleGoogleSignIn}
                  disabled={loading}
                  className="w-full h-14 rounded-md text-base font-semibold bg-white hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700 text-foreground border border-gray-200/50 dark:border-gray-700 shadow-sm transition-all active:scale-[0.98] flex items-center justify-center gap-3"
                  variant="outline"
                >
                  <svg className="h-5 w-5" viewBox="0 0 24 24">
                    <path
                      fill="#4285F4"
                      d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                    />
                    <path
                      fill="#34A853"
                      d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                    />
                    <path
                      fill="#FBBC05"
                      d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                    />
                    <path
                      fill="#EA4335"
                      d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                    />
                  </svg>
                  Continuar com Google
                </Button>

                {isIOS && (
                  <Button
                    onClick={handleAppleSignIn}
                    disabled={loading}
                    className="w-full h-14 rounded-md text-base font-semibold bg-black hover:bg-black/90 text-white shadow-sm transition-all active:scale-[0.98] flex items-center justify-center gap-3"
                  >
                    <svg
                      className="h-5 w-5"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                    >
                      <path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.04 2.26-.74 3.58-.8 1.56-.05 2.88.66 3.65 1.76-3.21 1.95-2.67 6.32.44 7.63-.73 1.63-1.63 3.08-2.75 3.58zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.32 2.37-2.03 4.41-3.74 4.25z" />
                    </svg>
                    Continuar com Apple
                  </Button>
                )}

                {/* Divider */}
                <div className="relative py-2">
                  <div className="absolute inset-0 flex items-center">
                    <span className="w-full border-t border-gray-200/40" />
                  </div>
                  <div className="relative flex justify-center text-xs uppercase">
                    <span className="bg-transparent px-3 text-gray-500/70">
                      ou
                    </span>
                  </div>
                </div>

                <Button
                  onClick={() => setView("login")}
                  className="w-full h-14 rounded-md text-base font-semibold shadow-sm transition-all hover:shadow-sm hover: active:scale-[0.98]"
                >
                  <LogIn className="mr-2 h-5 w-5" />
                  Entrar com Email
                </Button>

                <Button
                  onClick={() => setView("register")}
                  variant="ghost"
                  className="w-full h-12 rounded-md text-base font-medium text-gray-500 dark:text-gray-400 hover:text-foreground hover:bg-white dark:hover:bg-gray-800 border border-gray-200 dark:border-gray-700 transition-all active:scale-[0.98]"
                >
                  <UserPlus className="mr-2 h-5 w-5" />
                  Criar Conta
                </Button>
              </div>

              {/* Removed Stats/Social Proof as requested */}
            </div>
          </div>
        )}

        {/* LOGIN / REGISTER VIEW */}
        {(view === "login" || view === "register") && (
          <>
            {/* Back Button */}
            <div className="px-4 pt-4 pb-2">
              <button
                onClick={goToLanding}
                className="flex items-center gap-2 text-gray-500 hover:text-foreground transition-colors p-2 -ml-2 rounded-md active:bg-muted/50"
              >
                <ArrowLeft className="h-5 w-5" />
                <span className="text-sm font-medium">Voltar</span>
              </button>
            </div>

            {/* Header */}
            <header
              className={cn(
                "flex flex-col items-center pb-4 px-4 transition-all duration-500",
                mounted
                  ? "opacity-100 translate-y-0"
                  : "opacity-0 -translate-y-4"
              )}
            >
              <div className="relative mb-3">
                <div className="flex h-20 w-20 items-center justify-center rounded-md shadow-sm ">
                  <Sparkles className="h-10 w-10 text-primary-foreground" />
                </div>
                <div className="absolute -right-0.5 -top-0.5 h-4 w-4 rounded-full bg-fresh animate-pulse" />
              </div>
              <h1 className="text-2xl font-bold tracking-tight text-foreground">
                FRIGGO
              </h1>
            </header>

            {/* Auth Form Card */}
            <div className="flex-1 px-4 animate-fade-in overflow-y-auto">
              <div className="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 backdrop-blur-xl rounded-3xl shadow-sm p-6 max-w-sm mx-auto">
                <form onSubmit={handleSubmit} className="space-y-4">
                  {/* Greeting */}
                  <div className="mb-5 text-center">
                    <h2 className="text-xl font-bold text-foreground">
                      {view === "login"
                        ? "Bem-vindo de volta!"
                        : "Crie sua conta"}
                    </h2>
                    <p className="text-sm text-gray-500 mt-1">
                      {view === "login"
                        ? "Entre para continuar"
                        : "Comece a organizar sua casa"}
                    </p>
                  </div>

                  {/* Name Field (only for register) */}
                  {view === "register" && (
                    <div className="space-y-2 animate-fade-in">
                      <Label className="text-foreground text-sm font-medium">
                        Nome
                      </Label>
                      <div className="relative group">
                        <User className="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-500 group-focus-within:text-primary transition-colors" />
                        <Input
                          type="text"
                          placeholder="Seu nome"
                          value={formData.name}
                          onChange={(e) =>
                            setFormData({ ...formData, name: e.target.value })
                          }
                          className="pl-12 h-14 bg-background/50 border-gray-200/50 rounded-md text-base transition-all focus:bg-background focus:shadow-sm"
                        />
                      </div>
                    </div>
                  )}

                  {/* Email */}
                  <div className="space-y-2">
                    <Label className="text-foreground text-sm font-medium">
                      Email
                    </Label>
                    <div className="relative group">
                      <Mail className="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-500 group-focus-within:text-primary transition-colors" />
                      <Input
                        type="email"
                        placeholder="seu@email.com"
                        value={formData.email}
                        onChange={(e) =>
                          setFormData({ ...formData, email: e.target.value })
                        }
                        className="pl-12 h-14 bg-background/50 border-gray-200/50 rounded-md text-base transition-all focus:bg-background focus:shadow-sm"
                        autoComplete="email"
                        name="email"
                        inputMode="email"
                        required
                      />
                    </div>
                  </div>

                  {/* Password */}
                  <div className="space-y-2">
                    <Label className="text-foreground text-sm font-medium">
                      Senha
                    </Label>
                    <div className="relative group">
                      <Lock className="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-500 group-focus-within:text-primary transition-colors" />
                      <Input
                        type={showPassword ? "text" : "password"}
                        placeholder="••••••••"
                        value={formData.password}
                        onChange={(e) =>
                          setFormData({ ...formData, password: e.target.value })
                        }
                        className="pl-12 pr-12 h-14 bg-background/50 border-gray-200/50 rounded-md text-base transition-all focus:bg-background focus:shadow-sm"
                        autoComplete={
                          view === "login" ? "current-password" : "new-password"
                        }
                        name="password"
                        required
                      />
                      <button
                        type="button"
                        onClick={() => setShowPassword(!showPassword)}
                        className="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-foreground transition-colors p-1"
                      >
                        {showPassword ? (
                          <EyeOff className="h-5 w-5" />
                        ) : (
                          <Eye className="h-5 w-5" />
                        )}
                      </button>
                    </div>
                  </div>

                  {/* Confirm Password (only for register) */}
                  {view === "register" && (
                    <div className="space-y-2 animate-fade-in">
                      <Label className="text-foreground text-sm font-medium">
                        Confirmar Senha
                      </Label>
                      <div className="relative group">
                        <Lock className="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-500 group-focus-within:text-primary transition-colors" />
                        <Input
                          type={showPassword ? "text" : "password"}
                          placeholder="••••••••"
                          value={formData.confirmPassword}
                          onChange={(e) =>
                            setFormData({
                              ...formData,
                              confirmPassword: e.target.value
                            })
                          }
                          className="pl-12 h-14 bg-background/50 border-gray-200/50 rounded-md text-base transition-all focus:bg-background focus:shadow-sm"
                          autoComplete="new-password"
                          required
                        />
                      </div>
                    </div>
                  )}

                  {/* Forgot Password */}
                  {view === "login" && (
                    <div className="text-right">
                      <button
                        type="button"
                        onClick={() => setResetDialogOpen(true)}
                        className="text-sm text-primary hover:underline font-medium transition-colors"
                      >
                        Esqueceu a senha?
                      </button>
                    </div>
                  )}

                  {/* Submit Button */}
                  <Button
                    type="submit"
                    disabled={loading}
                    className="w-full h-14 rounded-md text-base font-semibold shadow-sm transition-all hover:shadow-sm active:scale-[0.98] mt-2"
                  >
                    {loading ? (
                      <Loader2 className="h-5 w-5 animate-spin" />
                    ) : (
                      <>
                        {view === "login" ? "Entrar" : "Criar minha conta"}
                        <ArrowRight className="ml-2 h-5 w-5" />
                      </>
                    )}
                  </Button>

                  {/* Divider */}
                  <div className="relative py-3">
                    <div className="absolute inset-0 flex items-center">
                      <span className="w-full border-t border-gray-200/50" />
                    </div>
                    <div className="relative flex justify-center text-xs uppercase">
                      <span className="bg-white dark:bg-gray-900 px-3 text-gray-500">
                        ou continue com
                      </span>
                    </div>
                  </div>

                  {/* Google Sign In */}
                  <Button
                    type="button"
                    variant="outline"
                    disabled={loading}
                    onClick={handleGoogleSignIn}
                    className="w-full h-14 rounded-md text-base font-medium bg-background/50 border-gray-200/50 hover:bg-background transition-all active:scale-[0.98] flex items-center justify-center gap-3 mb-3"
                  >
                    <svg className="h-5 w-5" viewBox="0 0 24 24">
                      <path
                        fill="#4285F4"
                        d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                      />
                      <path
                        fill="#34A853"
                        d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                      />
                      <path
                        fill="#FBBC05"
                        d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                      />
                      <path
                        fill="#EA4335"
                        d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                      />
                    </svg>
                    Entrar com Google
                  </Button>

                  {isIOS && (
                    <Button
                      type="button"
                      disabled={loading}
                      onClick={handleAppleSignIn}
                      className="w-full h-14 rounded-md text-base font-medium bg-black hover:bg-black/90 text-white transition-all active:scale-[0.98] flex items-center justify-center gap-3"
                    >
                      <svg
                        className="h-5 w-5"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                      >
                        <path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.04 2.26-.74 3.58-.8 1.56-.05 2.88.66 3.65 1.76-3.21 1.95-2.67 6.32.44 7.63-.73 1.63-1.63 3.08-2.75 3.58zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.32 2.37-2.03 4.41-3.74 4.25z" />
                      </svg>
                      Entrar com Apple
                    </Button>
                  )}

                  {/* Switch View */}
                  <div className="text-center pt-2">
                    <span className="text-sm text-gray-500">
                      {view === "login" ? "Não tem conta? " : "Já tem conta? "}
                    </span>
                    <button
                      type="button"
                      onClick={() =>
                        setView(view === "login" ? "register" : "login")
                      }
                      className="text-sm text-primary font-semibold hover:underline"
                    >
                      {view === "login" ? "Criar conta" : "Entrar"}
                    </button>
                  </div>
                </form>
              </div>
            </div>

            {/* Bottom Spacer */}
            <div className="h-6" />
          </>
        )}
      </div>

      {/* Reset Password Dialog */}
      <Dialog open={resetDialogOpen} onOpenChange={setResetDialogOpen}>
        <DialogContent className="max-w-[calc(100vw-2rem)] sm:max-w-md rounded-3xl">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2 text-foreground">
              <KeyRound className="h-5 w-5 text-primary" />
              Recuperar Senha
            </DialogTitle>
            <DialogDescription>
              Digite seu email para receber um link de recuperação.
            </DialogDescription>
          </DialogHeader>

          {resetSent ? (
            <div className="flex flex-col items-center py-6 text-center">
              <div className="h-16 w-16 rounded-full bg-fresh/20 flex items-center justify-center mb-4">
                <CheckCircle2 className="h-8 w-8 text-fresh" />
              </div>
              <h3 className="font-semibold text-lg mb-2 text-foreground">
                Email Enviado!
              </h3>
              <p className="text-sm text-gray-500 mb-4">
                Verifique sua caixa de entrada em <strong>{resetEmail}</strong>
              </p>
              <Button
                onClick={closeResetDialog}
                className="w-full h-12 rounded-md"
              >
                Entendi
              </Button>
            </div>
          ) : (
            <form onSubmit={handlePasswordReset} className="space-y-4 mt-2">
              <div className="space-y-2">
                <Label className="text-sm">Email</Label>
                <div className="relative">
                  <Mail className="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-500" />
                  <Input
                    type="email"
                    placeholder="seu@email.com"
                    value={resetEmail}
                    onChange={(e) => setResetEmail(e.target.value)}
                    className="pl-12 h-14 rounded-md"
                  />
                </div>
              </div>

              <div className="flex gap-3">
                <Button
                  type="button"
                  variant="outline"
                  onClick={closeResetDialog}
                  className="flex-1 h-12 rounded-md"
                >
                  Cancelar
                </Button>
                <Button
                  type="submit"
                  disabled={resetLoading}
                  className="flex-1 h-12 rounded-md"
                >
                  {resetLoading ? (
                    <Loader2 className="h-5 w-5 animate-spin" />
                  ) : (
                    "Enviar"
                  )}
                </Button>
              </div>
            </form>
          )}
        </DialogContent>
      </Dialog>
    </div>
  );
}
