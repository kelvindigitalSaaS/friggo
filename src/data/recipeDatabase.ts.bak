// Função para gerar ID único
const generateId = () => Math.random().toString(36).substring(2, 9);

// Mapeamento de palavras-chave → photo ID do Unsplash (formato WebP automático)
const B = "https://images.unsplash.com/";
const S = "?auto=format&fm=webp&fit=crop&q=80&w=400&h=300";
const IMGS: { test: (n: string) => boolean; url: string }[] = [
  {
    test: (n) =>
      n.includes("brigadeiro") ||
      (n.includes("chocolate") && !n.includes("bolo")),
    url: `${B}photo-1571115177098-24ec42ed204d${S}`
  },
  {
    test: (n) => n.includes("bolo") || n.includes("cake"),
    url: `${B}photo-1578985545062-69928b1d9587${S}`
  },
  {
    test: (n) => n.includes("pudim") || n.includes("caramel"),
    url: `${B}photo-1551024506-0bccd828d307${S}`
  },
  {
    test: (n) =>
      n.includes("sorvete") || n.includes("gelato") || n.includes("ice cream"),
    url: `${B}photo-1567563297580-db70965c6bc1${S}`
