function getRecipeImage(name: string, type: string): string {
  const n = name
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase();
  for (const { test, url } of IMGS) {
    if (test(n)) return url;
  }
  // Fallback por tipo
  if (type === "dessert" || type === "sobremesa" || type === "doce")
    return `${B}photo-1565958011703-44f9829ba187${S}`;
  if (type === "healthy") return `${B}photo-1512621776951-a57141f2eefd${S}`;
  if (type === "meal-prep") return `${B}photo-1540189549336-e6e99c3679fe${S}`;
  if (type === "snack" || type === "lanche")
    return `${B}photo-1586190848861-99aa4a171e90${S}`;
  return `${B}photo-1546069901-ba9599a7e63c${S}`;
}

// Combina todas as receitas, deduplica por nome e adiciona IDs, usesExpiringItems e imageUrl
export const allRecipes: Recipe[] = (() => {
  const seen = new Set<string>();
  return [
    ...brazilianRecipes,
    ...additionalRecipes,
    ...receitasMassas,
    ...receitasCarnes,
    ...receitasAves,
    ...receitasFrutosMar,
    ...receitasSopas,
    ...receitasSaladas,
    ...receitasVegetariano,
    ...receitasRisotos,
    ...receitasGrelhados,
    ...receitasDoces,
    ...receitasBolos,
    ...receitasPaes,
    ...receitasCafeDaManha,
    ...receitasFitness,
    ...receitasLanches,
    ...receitasCozinhaAsiatica,
    ...receitasMexicana,
    ...receitasVegano,
    ...receitasDocesExtra,
    ...receitasCafeManha2,
    ...receitasBebidas,
    ...receitasFrangoEspecial,
    ...receitasPeixes,
    ...receitasMassasExtra,
    ...receitasChurrasco,
    ...receitasMegaPack,
    ...receitasBulk,
    ...receitasBulk3,
    ...receitasBulk2,
    ...receitasBulk4,
    ...receitasBulk5,
    ...receitasBulk6,
    ...receitasBulk7
  ]
    .filter((recipe) => {
      const key = recipe.name.toLowerCase().trim();
      if (seen.has(key)) return false;
      seen.add(key);
      return true;
    })
    .map((recipe) => ({
      ...recipe,
      id: generateId(),
      instructions: (recipe as any).instructions?.length
        ? (recipe as any).instructions
        : ((recipe as any).steps ?? []),
      usesExpiringItems: false,
      imageUrl: undefined
    }));
})();

// Exporta por categoria para facilitar filtros
export const recipesByType = {
  lunch: allRecipes.filter((r) => r.type === "lunch"),
  lanche: allRecipes.filter((r) => r.type === "lanche"),
  snack: allRecipes.filter((r) => r.type === "snack"),
  dessert: allRecipes.filter((r) => r.type === "dessert")
};

// Exporta por categoria culinária
export const recipesByCategory = allRecipes.reduce<Record<string, Recipe[]>>(
  (acc, recipe) => {
    const cat = recipe.category || "Outras";
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(recipe);
    return acc;
  },
  {}
);

// Lista de todas as categorias disponíveis
export const availableCategories = Object.keys(recipesByCategory).sort();

// Função para buscar receitas por ingredientes
export function findRecipesByIngredients(
  availableIngredients: string[]
): Recipe[] {
  const normalizedIngredients = availableIngredients.map((i) =>
    i.toLowerCase().trim()
  );

  return allRecipes
    .map((recipe) => {
      const matchingIngredients = recipe.ingredients.filter((ingredient) =>
        normalizedIngredients.some(
          (avail) =>
            ingredient.toLowerCase().includes(avail) ||
            avail.includes(ingredient.toLowerCase())
        )
      );
      return {
        ...recipe,
        matchScore: matchingIngredients.length / recipe.ingredients.length,
        matchingCount: matchingIngredients.length
      };
    })
    .filter((r) => r.matchScore > 0.3)
    .sort((a, b) => b.matchScore - a.matchScore);
}

// Função para buscar receitas que usam itens próximos do vencimento
export function findRecipesForExpiringItems(
  expiringItemNames: string[]
): Recipe[] {
  const normalizedItems = expiringItemNames.map((i) => i.toLowerCase().trim());

  return allRecipes
    .filter((recipe) =>
      recipe.ingredients.some((ingredient) =>
        normalizedItems.some(
          (item) =>
            ingredient.toLowerCase().includes(item) ||
            item.includes(ingredient.toLowerCase())
        )
      )
    )
    .map((recipe) => ({ ...recipe, usesExpiringItems: true }));
}

// Estatísticas
export const recipeStats = {
  total: allRecipes.length,
  byType: {
    lunch: recipesByType.lunch.length,
    lanche: recipesByType.lanche.length,
    snack: recipesByType.snack.length,
    dessert: recipesByType.dessert.length
  }
};

export default allRecipes;
