<?xml version="1.0" encoding="utf-8" ?>
<!--
  Google App Actions for Friggo.
  Allows Google Assistant to open specific screens via deep links.
  See: https://developers.google.com/assistant/app/get-started
-->
<actions>
    <!-- "Ok Google, abrir Friggo" -->
    <action intentName="actions.intent.OPEN_APP_FEATURE">
        <fulfillment urlTemplate="friggo://home{?feature}">
            <parameter-mapping intentParameter="feature" urlParameter="tab" />
        </fulfillment>
    </action>

    <!-- "Ok Google, adicionar item na geladeira" / "Ok Google, add [item] to Friggo" -->
    <action intentName="actions.intent.CREATE_THING">
        <fulfillment urlTemplate="friggo://add-item{?name}">
            <parameter-mapping
        intentParameter="thing.name"
        urlParameter="name"
      />
        </fulfillment>
    </action>

    <!-- "Ok Google, o que tem na geladeira?" / "Ok Google, show my fridge" -->
    <action intentName="actions.intent.GET_THING">
        <fulfillment urlTemplate="friggo://home?tab=fridge" />
    </action>

    <!-- "Ok Google, receitas no Friggo" -->
    <action intentName="actions.intent.GET_FOOD_OBSERVATION">
        <fulfillment urlTemplate="friggo://home?tab=recipes" />
    </action>
</actions>
